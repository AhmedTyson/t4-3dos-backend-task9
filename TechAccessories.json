                  "type": "text"
                },
                {
                  "key": "base_price",
                  "value": "350.00",
                  "type": "text"
                },
                {
                  "key": "stock",
                  "value": "50",
                  "type": "text"
                },
                {
                  "key": "in_stock",
                  "value": "1",
                  "type": "text"
                },
                {
                  "key": "images[]",
                  "value": "",
                  "type": "file",
                  "description": "Upload product images (multiple allowed)"
                }
              ]
