                  "key": "per_page",
                  "value": "",
                  "description": "Items per page (optional, max 100)",
                  "disabled": true
                },
                {
                  "key": "category_id",
                  "value": "",
                  "description": "Filter by category ID (optional)",
                  "disabled": true
                },
                {
                  "key": "min_price",
                  "value": "",
                  "description": "Minimum price (optional)",
                  "disabled": true
                },
                {
                  "key": "max_price",
                  "value": "",
                  "description": "Maximum price (optional)",
                  "disabled": true
                },
                {
                  "key": "search",
