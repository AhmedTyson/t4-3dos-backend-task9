            "description": "Create a new product. Admin only. Use form-data for image uploads.",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "category_id",
                  "value": "1",
                  "type": "text"
                },
                {
                  "key": "name",
                  "value": "Mechanical Wireless Keyboard",
                  "type": "text"
                },
                {
                  "key": "description",
