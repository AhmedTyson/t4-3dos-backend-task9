          },
          "response": []
        },
        {
          "name": "Update Product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/products/{{product_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "products",
                "{{product_id}}"
              ]
            },
            "description": "Update an existing product. Admin only. Uses POST + _method=PUT for multipart. Partial update allowed.",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "_method",
                  "value": "PUT",
                  "type": "text"
                },
                {
                  "key": "category_id",
                  "value": "1",
                  "type": "text"
                },
                {
                  "key": "name",
                  "value": "Mechanical Wireless Keyboard v2",
                  "type": "text"
                },
                {
                  "key": "description",
                  "value": "Updated description",
                  "type": "text"
                },
                {
                  "key": "size",
                  "value": "Full Size",
                  "type": "text"
                },
                {
                  "key": "base_price",
                  "value": "380.00",
                  "type": "text"
                },
                {
                  "key": "stock",
                  "value": "40",
                  "type": "text"
                },
                {
                  "key": "in_stock",
                  "value": "1",
                  "type": "text"
                },
                {
                  "key": "image",
                  "value": "",
                  "type": "file",
                  "description": "Upload single product image (file upload)"
                },
                {
                  "key": "image_url",
                  "value": "",
                  "type": "text",
                  "description": "Or provide image URL instead of file upload"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/products/{{product_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "products",
                "{{product_id}}"
              ]
            },
            "description": "Soft delete a product. Admin only. 409 if has order history."
          },
          "response": []
        }
